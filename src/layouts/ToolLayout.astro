---
import Layout from './Layout.astro';
import App from '../components/App.svelte';
import ThreeDBackground from '../components/ThreeDBackground.svelte';

interface Props {
  title: string;
  h1: string;
  description: string;
  unit: string;
  content: string;
}

const { title, h1, description, unit, content } = Astro.props;
---

<Layout title={title} description={description}>
    <ThreeDBackground client:only="svelte" />
	<main class="relative bg-canvas dark:bg-canvas text-ink dark:text-ink selection:bg-ink selection:text-canvas">
		
        <div class="max-w-7xl mx-auto px-6 pt-32 pb-12 text-center relative z-10">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-md border border-hairline bg-canvas-soft text-ink dark:text-ink text-[10px] font-bold uppercase tracking-widest mb-8 animate-in fade-in slide-in-from-bottom-4 duration-1000 ease-out">
				<span class="w-1.5 h-1.5 rounded-full bg-ink dark:bg-ink animate-pulse"></span>
				Professional Tool
			</div>

			<h1 class="text-5xl md:text-7xl font-black tracking-tighter leading-tight max-w-5xl mx-auto mb-8 animate-in fade-in slide-in-from-bottom-8 duration-1000 delay-100">
				{h1}<span class="text-mute font-medium">.</span>
			</h1>
			
			<p class="text-lg md:text-2xl text-body max-w-3xl mx-auto mb-16 leading-relaxed animate-in fade-in slide-in-from-bottom-12 duration-1000 delay-200">
				{description}
			</p>

            <!-- App Container (Embedded) -->
            <div class="mb-32 relative reveal-card active">
                <div class="absolute -inset-4 bg-gradient-to-b from-ink/5 to-transparent blur-3xl -z-10 rounded-[3rem]"></div>
		        <App client:only="svelte" initialUnit={unit} isEmbedded={true} />
            </div>

            <div class="flex items-center justify-center gap-6 mb-32 reveal-card active" style="transition-delay: 150ms;">
				<button class="btn-black shadow-2xl" onclick="window.dispatchEvent(new CustomEvent('open-calibration'))">Calibrate for Accuracy</button>
                <a href="/how-it-works" class="btn-white">Calibration Guide</a>
			</div>

            <!-- SEO Content Section -->
            <section class="max-w-4xl mx-auto text-left py-24 border-t border-hairline reveal-card" style="transition-delay: 200ms;">
                <h2 class="text-4xl font-black tracking-tighter mb-12">Professional Grade Accuracy</h2>
                <div class="prose prose-xl prose-neutral dark:prose-invert max-w-none">
                    <div set:html={content} />
                    <p class="mt-8">
                        Whether you are using a mobile phone, a tablet, or a high-resolution desktop monitor, the key to an <strong>accurate online ruler</strong> is matching the software to your hardware. 
                        By following our <strong>ruler calibration</strong> process, you can ensure that the measurements you see are 100% reliable for professional and personal use.
                    </p>
                </div>
            </section>
		</div>
	</main>
</Layout>

<style is:global>
    /* Reuse the reveal-card styles */
    .reveal-card {
        opacity: 0;
        transform: translateY(60px);
        filter: blur(10px);
        transition: all 1.2s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .reveal-card.active {
        opacity: 1;
        transform: translateY(0);
        filter: blur(0);
    }
</style>

<script>
    // Simple intersection observer for the landing page cards
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) entry.target.classList.add('active');
        });
    }, { threshold: 0.1 });

    function setupReveal() {
        document.querySelectorAll('.reveal-card').forEach(c => observer.observe(c));
    }

    document.addEventListener('DOMContentLoaded', setupReveal);
    document.addEventListener('astro:after-swap', setupReveal);
</script>
